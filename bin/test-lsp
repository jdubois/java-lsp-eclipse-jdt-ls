#!/usr/bin/env bash
# Integration test: verify the Java LSP server can start and analyze a Java file.
#
# This script:
#   1. Checks prerequisites (Java 21+, JDTLS installed or auto-downloaded)
#   2. Starts Eclipse JDTLS via the same configuration as the launcher
#   3. Sends LSP 'initialize' and 'textDocument/didOpen' requests
#   4. Verifies the server responds and can analyze the example Calculator.java
#   5. Sends 'shutdown' and 'exit' to cleanly stop the server
#
# Usage: ./bin/test-lsp
#   Requires Java 21+ and JDTLS (auto-downloads if not present).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGIN_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
# shellcheck source=lib/common.sh
source "$SCRIPT_DIR/lib/common.sh"

PASS="✓"
FAIL="✗"
ERRORS=0

# --- Helper: format an LSP message with Content-Length header ---
lsp_msg() {
  local body="$1"
  printf "Content-Length: %d\r\n\r\n%s" "${#body}" "$body"
}

# --- Helper: escape file content for JSON string embedding ---
json_escape() {
  sed 's/\\/\\\\/g; s/"/\\"/g; s/\t/\\t/g' | awk '{printf "%s\\n", $0}' | sed '$ s/\\n$//'
}

echo "Testing Java LSP (Eclipse JDT LS) integration..."
echo ""

# =============================================
# Step 1: Verify prerequisites
# =============================================
if ! resolve_java; then
  if [ -n "${JAVA_VERSION:-}" ]; then
    echo "$FAIL Java 21+ is required, but found Java $JAVA_VERSION."
  else
    echo "$FAIL Java not found. Set JAVA_HOME or add java to your PATH."
  fi
  exit 1
fi
echo "$PASS Java $JAVA_VERSION found ($JAVA)"

if ! find_jdtls; then
  echo "  Eclipse JDTLS not found. Attempting auto-download..." >&2
  if ! download_jdtls; then
    echo "$FAIL Eclipse JDTLS not found and auto-download failed."
    exit 1
  fi
fi
echo "$PASS Eclipse JDTLS found ($JDTLS_HOME)"

if ! find_launcher_jar; then
  echo "$FAIL Equinox launcher JAR not found in $JDTLS_HOME/plugins/"
  exit 1
fi
echo "$PASS Equinox launcher JAR found"

if ! detect_config_dir; then
  echo "$FAIL Platform config directory not found"
  exit 1
fi
echo "$PASS Platform config directory ($CONFIG_DIR)"

# =============================================
# Step 2: Verify example Java file
# =============================================
EXAMPLE_FILE="$PLUGIN_DIR/examples/Calculator.java"
if [ ! -f "$EXAMPLE_FILE" ]; then
  echo "$FAIL Example file not found: examples/Calculator.java"
  exit 1
fi
echo "$PASS Example Calculator.java found"
echo ""

# =============================================
# Step 3: Start LSP server and test protocol
# =============================================
WORK_DIR=$(mktemp -d)
DATA_DIR=$(mktemp -d)
SERVER_PID=""

cleanup() {
  if [ -n "$SERVER_PID" ]; then
    kill "$SERVER_PID" 2>/dev/null || true
    wait "$SERVER_PID" 2>/dev/null || true
  fi
  rm -rf "$WORK_DIR" "$DATA_DIR"
}
trap cleanup EXIT

cp "$EXAMPLE_FILE" "$WORK_DIR/"
FIFO_IN="$WORK_DIR/lsp_stdin"
mkfifo "$FIFO_IN"

echo "Starting LSP server..."

# Start JDTLS in the background
"$JAVA" \
  -Declipse.application=org.eclipse.jdt.ls.core.id1 \
  -Dosgi.bundles.defaultStartLevel=4 \
  -Declipse.product=org.eclipse.jdt.ls.core.product \
  -Dlog.level=WARN \
  -Xms512m \
  -Xmx2G \
  -XX:+UseStringDeduplication \
  --add-modules=ALL-SYSTEM \
  --add-opens java.base/java.util=ALL-UNNAMED \
  --add-opens java.base/java.lang=ALL-UNNAMED \
  -jar "$LAUNCHER_JAR" \
  -configuration "$CONFIG_DIR" \
  -data "$DATA_DIR" \
  < "$FIFO_IN" > "$WORK_DIR/lsp_stdout" 2>"$WORK_DIR/lsp_stderr" &
SERVER_PID=$!

# Open the write end of the pipe (keeps server stdin open)
exec 3>"$FIFO_IN"

# Give the server time to start up
sleep 5

if ! kill -0 "$SERVER_PID" 2>/dev/null; then
  echo "$FAIL Server crashed on startup"
  echo "  stderr:" >&2
  head -20 "$WORK_DIR/lsp_stderr" >&2
  ERRORS=$((ERRORS + 1))
  exit 1
fi
echo "$PASS Server started (PID: $SERVER_PID)"

# --- Send LSP initialize request ---
WORKSPACE_URI="file://$WORK_DIR"
INIT='{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"processId":'"$$"',"rootUri":"'"$WORKSPACE_URI"'","capabilities":{},"workspaceFolders":[{"uri":"'"$WORKSPACE_URI"'","name":"test"}]}}'
lsp_msg "$INIT" >&3

# Wait for server to process initialize
sleep 10

if ! kill -0 "$SERVER_PID" 2>/dev/null; then
  echo "$FAIL Server crashed after initialize request"
  ERRORS=$((ERRORS + 1))
else
  if [ -s "$WORK_DIR/lsp_stdout" ] && grep -q "Content-Length" "$WORK_DIR/lsp_stdout"; then
    echo "$PASS Server responded to initialize request"
  else
    echo "$FAIL No LSP response received for initialize"
    ERRORS=$((ERRORS + 1))
  fi
fi

# --- Send initialized notification ---
INITIALIZED='{"jsonrpc":"2.0","method":"initialized","params":{}}'
lsp_msg "$INITIALIZED" >&3
sleep 2

# --- Send textDocument/didOpen for Calculator.java ---
FILE_URI="file://$WORK_DIR/Calculator.java"
JAVA_TEXT=$(json_escape < "$WORK_DIR/Calculator.java")
DID_OPEN='{"jsonrpc":"2.0","method":"textDocument/didOpen","params":{"textDocument":{"uri":"'"$FILE_URI"'","languageId":"java","version":1,"text":"'"$JAVA_TEXT"'"}}}'
lsp_msg "$DID_OPEN" >&3

# Wait for analysis
sleep 10

if ! kill -0 "$SERVER_PID" 2>/dev/null; then
  echo "$FAIL Server crashed while analyzing Calculator.java"
  ERRORS=$((ERRORS + 1))
else
  echo "$PASS Server analyzed Calculator.java without errors"
fi

# --- Shutdown and exit ---
SHUTDOWN='{"jsonrpc":"2.0","id":2,"method":"shutdown","params":null}'
lsp_msg "$SHUTDOWN" >&3
sleep 2

EXIT_MSG='{"jsonrpc":"2.0","method":"exit","params":null}'
lsp_msg "$EXIT_MSG" >&3

# Close the write end of the pipe
exec 3>&-

# Wait for server to exit
wait "$SERVER_PID" 2>/dev/null || true
SERVER_PID=""
echo "$PASS Server shutdown cleanly"

# =============================================
# Summary
# =============================================
echo ""
if [ "$ERRORS" -eq 0 ]; then
  echo "All LSP integration tests passed."
else
  echo "$ERRORS test(s) failed."
  exit 1
fi
